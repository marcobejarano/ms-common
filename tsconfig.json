{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "lib": ["ES2022"],

    "strict": true,

    "declaration": true,
    "declarationMap": true,

    "outDir": "./dist",
    "rootDir": "./src",

    "verbatimModuleSyntax": true,
    "isolatedModules": true,

    "skipLibCheck": true,

    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,

    "types": ["bun"]
  },
  "include": ["src"]
}
